// operations go sequentially in precedence from left to right
// a :: -1().* * b[10] + e == "abc" < .hello || .great && .not
// here they are parenthesized to show how they are parsed explicitly
// a :: ((((((-1().* * b[10]) + e) == "abc") < .hello) || .great) && .not)

foo :: "example"
       "multiline"
       "string"

