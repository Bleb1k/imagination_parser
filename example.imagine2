TokenType :: enum u8 {
  null
  eof
  identifier
  arrow
  arrow_fat
  int
  intl
  intll
  intu
  intul
  intull
  float32
  float64
  float128
  string
  true_
  false_
  comment
  char
  symbol
}

TokenValue :: enum TokenType {
  identifier = .identifier
  int        = .int
  intl       = .intl
  intll      = .intll
  intu       = .intu
  intul      = .intul
  intull     = .intull
  float32    = .float32
  float64    = .float64
  float128   = .float128
  string     = .string
  true       = .true
  false      = .false
  char       = .char
}

is_str_here
: ([]char, []char) -> void
: (src, needle: []char) -> {
  if len(src) < len(needle) {return false}
  for needle if it != src[it_index] {return false}
  return true
}

Token :: struct {
  lexeme: []char
  type: TokenType
  line: int
}

Lexer :: struct {
  input: []char
  source_file_path: []char
  current_token: Token
  pos, last_newline_pos, line_count: int
}

Lexer.return_token :: (
  self: *Lexer,
  typ: TokenType,
  lexeme: []char
) -> {
  self.current_token = .{
    lexeme,
    type = typ,
    line = self.line_count
  }
  self.pos = self.input.(*char) - lexeme.(*char) + len(lexeme)
}

