// full
a: int : 1
b: char = 'b'

// implied
c :: true
d := "abcd"

// separate
e: int
e: 1
f: int
f = 2

// expressions
g: int : 1 + 2 + 3
h := 4 * 5 + 6
i: float = 10 - 12 / 21 

// c multiword types
j: (_Complex double) = 1 + 2i
k: (const unsigned long long int) = 0

